{
  "servers": [
    {
      "id": "sardineinternalsandbox",
      "name": "sardineInternalSandbox",
      "command": "npx",
      "args": [
        "@sardine-ai/internal-mcp",
        "--project-id",
        "sandbox-sardine-ai",
        "--location",
        "US",
        "--bigquery-project-id",
        "sandbox-sardine-users-bq"
      ],
      "disabled": true,
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "~/.config/gcloud/application_default_credentials.json"
      }
    },
    {
      "id": "sardineinternalproduction",
      "name": "sardineInternalProduction",
      "command": "npx",
      "args": [
        "@sardine-ai/internal-mcp",
        "--project-id",
        "prod-sardine-ai",
        "--location",
        "US",
        "--bigquery-project-id",
        "prod-sardine-users-bq"
      ],
      "disabled": true
    },
    {
      "id": "browsermcp",
      "name": "browsermcp",
      "command": "npx",
      "args": ["@browsermcp/mcp@latest"],
      "disabled": true
    },
    {
      "id": "gemini-mcp-tool",
      "name": "gemini-mcp-tool",
      "command": "npx",
      "args": ["-y", "gemini-mcp-tool"],
      "disabled": true
    },
    {
      "id": "brave-search",
      "name": "brave-search",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "disabled": true,
      "env": {
        "BRAVE_API_KEY": "REDACTED"
      }
    },
    {
      "id": "filesystem",
      "name": "filesystem",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/matex/Sardine/",
        "/Users/matex/Projects/",
        "/Users/matex/Documents/",
        "/Users/matex/Desktop/",
        "/Users/matex/Downloads/"
      ],
      "disabled": true
    },
    {
      "id": "fetch",
      "name": "fetch",
      "command": "uvx",
      "args": ["mcp-server-fetch", "--ignore-robots-txt"],
      "disabled": true
    },
    {
      "id": "sequential-thinking",
      "name": "sequential-thinking",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "disabled": true
    },
    {
      "id": "playwright",
      "name": "playwright",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "disabled": true
    },
    {
      "id": "chrome-devtools",
      "name": "chrome-devtools",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "disabled": true
    },
    {
      "id": "metamcp",
      "name": "metamcp",
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://localhost:12008/metamcp/default/mcp"
      ],
      "env": {
        "API_ACCESS_TOKEN": "REDACTED"
      },
      "disabled": true
    }
  ],
